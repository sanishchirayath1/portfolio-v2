# Copy to .env.local for development. Never commit real values.
#
# These are RUNTIME env var names (used by .env.local locally and by Vercel
# in production). GitHub Actions is stricter: secret names may NOT start with
# `GITHUB_`. Where a workflow needs one of these values, it stores it under a
# different secret name and re-exports it under the runtime name at job time.
# See `.github/workflows/*.yml` for the mapping.

# ─────────────────────────────────────────────────────────────
# GitHub — fine-grained PAT with public_repo:read, tied to sanishchirayath1.
# Used by lib/github.ts for the runtime project sync (M3) and by
# scripts/sync-github-snapshot.ts for the nightly fallback.
#
# How to generate:
#   1. https://github.com/settings/personal-access-tokens/new
#   2. Resource owner: sanishchirayath1
#   3. Repository access: Public Repositories (read-only)
#   4. Permissions → Repository → Metadata: Read-only (default)
#   5. Copy the token (starts with github_pat_) and paste below.
#
# Where this value goes:
#   - Local:          .env.local as GITHUB_TOKEN
#   - Vercel:         Project → Env Vars as GITHUB_TOKEN
#   - GitHub Actions: Repo Settings → Secrets as PORTFOLIO_GITHUB_TOKEN
#                     (the workflow re-exports it as env GITHUB_TOKEN)
# ─────────────────────────────────────────────────────────────
GITHUB_TOKEN=

GITHUB_TOKEN_PERSONAL=
# Secret used to verify GitHub webhook HMAC signatures on /api/revalidate.
# Set the same value on the webhook in GitHub repo settings.
#
# How to generate:
#   openssl rand -hex 32
#
# How to use:
#   1. GitHub repo → Settings → Webhooks → Add webhook.
#      - Payload URL: https://<domain>/api/revalidate
#      - Content type: application/json
#      - Secret: same value you paste below
#      - Events: push, repository, star, public, meta (or "send everything").
#
# Where this value goes:
#   - Local:          .env.local as GITHUB_WEBHOOK_SECRET
#   - Vercel:         Project → Env Vars as GITHUB_WEBHOOK_SECRET
#   - GitHub Actions: not used (webhook is hit from GitHub → your prod URL,
#                     no workflow reads this)
# ─────────────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=

# dev.to API key for syndication (M5).
#
# How to generate:
#   1. https://dev.to/settings/extensions
#   2. Scroll to "DEV Community API Keys", give it a name, click Generate API Key.
#   3. Copy and paste below.
#
# Where this value goes:
#   - Local:          .env.local as DEVTO_API_KEY (only needed to test
#                     `pnpm syndicate` locally without --dry-run)
#   - Vercel:         not used (runtime never syndicates)
#   - GitHub Actions: Repo Settings → Secrets as DEVTO_API_KEY
#                     (consumed by .github/workflows/syndicate.yml)
# ─────────────────────────────────────────────────────────────
DEVTO_API_KEY=

