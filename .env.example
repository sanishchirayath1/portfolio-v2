# Copy to .env.local for development. Never commit real values.

# ─────────────────────────────────────────────────────────────
# GitHub — fine-grained PAT with public_repo:read, tied to sanishchirayath1.
# Used by lib/github.ts for the runtime project sync (M3).
#
# How to generate:
#   1. https://github.com/settings/personal-access-tokens/new
#   2. Resource owner: sanishchirayath1
#   3. Repository access: Public Repositories (read-only)
#   4. Permissions → Repository → Metadata: Read-only (default)
#   5. Copy the token (starts with github_pat_) and paste below.
# ─────────────────────────────────────────────────────────────
GITHUB_TOKEN=

# Secret used to verify GitHub webhook HMAC signatures on /api/revalidate.
# Set the same value on the webhook in GitHub repo settings.
#
# How to generate:
#   openssl rand -hex 32
#
# How to use:
#   1. Paste the value below AND in Vercel → Project → Env Vars.
#   2. GitHub repo → Settings → Webhooks → Add webhook.
#      - Payload URL: https://<domain>/api/revalidate
#      - Content type: application/json
#      - Secret: same value as below
#      - Events: push, repository, star, public, meta (or "send everything").
# ─────────────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=

# dev.to API key for syndication (M5).
#
# How to generate:
#   1. https://dev.to/settings/extensions
#   2. Scroll to "DEV Community API Keys", give it a name, click Generate API Key.
#   3. Copy and paste below.
# ─────────────────────────────────────────────────────────────
DEVTO_API_KEY=

